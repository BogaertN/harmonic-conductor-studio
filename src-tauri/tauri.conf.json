{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Harmonic Conductor Studio",
  "version": "0.1.0",
  "identifier": "com.aiweb.harmonic-conductor-studio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Harmonic Conductor Studio",
        "width": 1280,
        "height": 820,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
